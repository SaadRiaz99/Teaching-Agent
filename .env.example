# --- LLM Configuration ---
# Option 1: Zen (free models via OpenCode Zen - no API key required for free tiers)
LLM_PROVIDER=zen
ZEN_API_KEY=
ZEN_API_BASE=https://opencode.ai/zen/v1
ZEN_MODEL=opencode/big-pickle

# Option 2: Ollama (completely free, local)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Option 3: OpenAI (paid API key required)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key-here

# Option 4: Claude (paid API key required)
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Embedding Configuration (free, no API/DLL required) ---
EMBEDDING_TYPE=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Vector Database ---
VECTOR_DB_TYPE=chroma
CHROMA_PERSIST_DIR=vectordb
COLLECTION_NAME=smit_documents

# Qdrant (optional)
# QDRANT_URL=http://localhost:6333

# Pinecone (optional)
# PINECONE_API_KEY=your-pinecone-key
# PINECONE_ENVIRONMENT=us-east-1-aws

# --- Chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=4

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501
DEBUG=false
LOG_LEVEL=INFO

# --- Upload ---
UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE_MB=50

# --- Conversation ---
CONVERSATION_HISTORY_LIMIT=10
